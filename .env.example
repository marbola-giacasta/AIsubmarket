# ============================================================
# Environment Variables — copy to .env and fill in your values
# ============================================================

# --- Auth ---
JWT_SECRET=your_super_secret_jwt_key_change_me

# --- Database (Supabase) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# --- Cloudflare DNS ---
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_ZONE_ID_OPENAICH=zone_id_for_open-ai_ch
CLOUDFLARE_ZONE_ID_OPENAILIVE=zone_id_for_open-ai_live
CLOUDFLARE_ZONE_ID_GEMINAI=zone_id_for_geminai_info
CLOUDFLARE_ZONE_ID_COURSEAI=zone_id_for_course-ai_co_uk

# --- Stripe (test mode) ---
# Get from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
SUBDOMAIN_PRICE_CENTS=999

# --- Email (Nodemailer) ---
# For Gmail: use an App Password (not your normal password)
# Generate at: https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=you@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_TO=admin@yourdomain.com

# --- Backend ---
PORT=3001
FRONTEND_URL=http://localhost:5173
